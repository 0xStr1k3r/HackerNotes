// Category → folder mapping (flat, for search)
const CAT_FOLDER = {
  "Web Pentesting":    "web-pentesting",
  "Penetration Testing": "pentesting",
  "Red Teaming":       "red-teaming",
  "Cloud Security":    "cloud-security",
  "API Pentesting":    "api-pentesting",
  "Active Directory":  "ad-pentesting"
};

// Flat notes list for search
function getAllNotes() {
  const all = [];
  Object.entries(NAV).forEach(([cat, data]) => {
    data.phases.forEach(phase => {
      phase.notes.forEach(note => {
        all.push({ ...note, category: cat, phase: phase.phase });
      });
    });
  });
  return all;
}
